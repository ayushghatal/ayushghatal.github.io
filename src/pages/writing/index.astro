---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineEntry from '../../components/TimelineEntry.astro';

const posts = Object.values(import.meta.glob('./*.mdx', { eager: true }))
  .filter(post => post.frontmatter?.title)
  .map(post => ({ ...post.frontmatter, category: post.frontmatter.category || "General", series: post.frontmatter.series || null, url: post.url }))
  .sort((a, b) => new Date(b.date) - new Date(a.date)); // newest first by default

const latestDate = Math.max(...posts.map(p => new Date(p.date).getTime()));
const categories = [...new Set(posts.map(p => p.category))];
const allSeries = [...new Set(posts.map(p => p.series).filter(Boolean))];
const seriesData = allSeries.map(name => ({
  name,
  count: posts.filter(p => p.series === name).length,
  posts: posts.filter(p => p.series === name),
}));
---
<BaseLayout title="writing">
  <h1 fetchpriority="high">writing</h1>
  <p class="subtitle">notes on embedded systems, FPGA, and physics.</p>

  <div class="controls">
    <div class="tabs" id="category-tabs">
      <button class="tab active" data-category="all" type="button">all</button>
      {categories.map(category => (
        <button class="tab" data-category={category} type="button">{category.toLowerCase()}</button>
      ))}
      {seriesData.length > 0 && (
        <button class="tab" data-category="__series__" type="button">series</button>
      )}
    </div>
    <button class="sort-toggle" id="sort-toggle" type="button" data-order="desc">
      newest first
    </button>
  </div>

  <div class="series-overview hidden" id="series-overview">
    {seriesData.map(s => (
      <button class="series-card" data-series={s.name} type="button">
        <span class="series-card-title">{s.name}</span>
        <span class="series-card-count">{s.count} post{s.count !== 1 ? 's' : ''}</span>
      </button>
    ))}
  </div>

  <div class="timeline" id="timeline">
    {posts.map(post => (
      <TimelineEntry
        title={post.title}
        description={post.description}
        date={post.date}
        category={post.category}
        series={post.series}
        tags={post.tags}
        url={post.url}
        featured={new Date(post.date).getTime() === latestDate}
      />
    ))}
  </div>

  <p class="no-results hidden" id="no-results">nothing matches.</p>
</BaseLayout>

<script>
  function setupWritingControls() {
    const tabsContainer = document.getElementById('category-tabs');
    const timeline = document.getElementById('timeline');
    const sortToggle = document.getElementById('sort-toggle');
    const noResults = document.getElementById('no-results');
    const overview = document.getElementById('series-overview');
    if (!timeline || !tabsContainer || !sortToggle || !noResults) return;

    let activeCategory = 'all';
    let view = 'posts'; // 'posts' | 'series' | 'series-posts'

    function render() {
      const entries = [...timeline.querySelectorAll('.entry')] as HTMLElement[];

      if (view === 'series') {
        entries.forEach(e => e.classList.add('hidden'));
        overview?.classList.remove('hidden');
        noResults.classList.add('hidden');
        return;
      }

      overview?.classList.add('hidden');
      const cat = (view === 'series-posts' || activeCategory === '__series__') ? 'all' : activeCategory;
      const seriesFilter = view === 'series-posts' ? activeCategory : null;
      let visibleCount = 0;

      entries.forEach(entry => {
        const el = entry as HTMLElement;
        const matchesCategory = cat === 'all' || el.dataset.category === cat;
        const matchesSeries = !seriesFilter || el.dataset.series === seriesFilter;
        const visible = matchesCategory && matchesSeries;
        el.classList.toggle('hidden', !visible);
        if (visible) visibleCount++;
      });

      noResults.classList.toggle('hidden', visibleCount > 0);
    }

    tabsContainer.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.tab') as HTMLElement | null;
      if (!btn) return;

      const cat = btn.dataset.category || 'all';
      tabsContainer.querySelectorAll('.tab').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');

      if (cat === '__series__') {
        view = 'series';
        activeCategory = '__series__';
      } else {
        view = 'posts';
        activeCategory = cat;
      }
      render();
    });

    overview?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.series-card') as HTMLElement | null;
      if (!card) return;

      const series = card.dataset.series;
      if (!series) return;

      view = 'series-posts';
      activeCategory = series;

      tabsContainer.querySelectorAll('.tab').forEach(p => {
        p.classList.toggle('active', p.dataset.category === '__series__');
      });
      render();
    });

    sortToggle.addEventListener('click', () => {
      const wasAscending = sortToggle.dataset.order === 'asc';
      const nowAscending = !wasAscending;
      sortToggle.dataset.order = nowAscending ? 'asc' : 'desc';
      sortToggle.textContent = nowAscending ? 'oldest first' : 'newest first';

      const entries = [...timeline.querySelectorAll('.entry')] as HTMLElement[];
      entries.sort((a, b) => {
        const diff = new Date(a.dataset.date!).getTime() - new Date(b.dataset.date!).getTime();
        return nowAscending ? diff : -diff;
      });
      entries.forEach(entry => timeline.appendChild(entry));
    });

    // Reset on page load
    view = 'posts';
    activeCategory = 'all';
    tabsContainer.querySelectorAll('.tab').forEach(p => p.classList.toggle('active', p.dataset.category === 'all'));
    render();
  }

  document.addEventListener('astro:page-load', setupWritingControls);
</script>

<style>
  .subtitle {
    color: var(--color-text-muted);
    margin-top: -0.5rem;
  }

  .controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
  }

  .tab {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 1px solid transparent;
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-text);
    border-bottom-color: var(--color-text);
  }

  .sort-toggle {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0;
  }

  .sort-toggle:hover {
    color: var(--color-text);
  }

  .sort-toggle::before {
    content: "↕ ";
  }

  .series-overview {
    margin-top: 2rem;
  }

  .series-overview.hidden {
    display: none;
  }

  .series-card {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 1rem 0;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  .series-card:last-child {
    border-bottom: none;
  }

  .series-card:hover .series-card-title {
    color: var(--color-text);
  }

  .series-card-title {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    transition: color 0.15s ease;
  }

  .series-card-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .no-results {
    margin-top: 2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .no-results.hidden {
    display: none;
  }

  .timeline {
    position: relative;
    margin-top: 0.5rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(5.5rem + 0.625rem);
    width: 1px;
    background: var(--color-border);
  }

  .timeline :global(.entry) {
    border-bottom: 1px solid var(--color-border);
    content-visibility: auto;
    contain-intrinsic-size: auto 140px;
  }

  .timeline :global(.entry:last-child) {
    border-bottom: none;
  }

  @media (max-width: 600px) {
    .timeline::before {
      left: calc(4rem + 0.5rem);
    }

    .controls {
      flex-direction: column;
      align-items: flex-start;
    }

    .tabs {
      gap: 0.9rem;
    }
  }
</style>
