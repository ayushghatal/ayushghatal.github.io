---
// Standalone CMS — no site layout.
import Login from '../../components/admin/Login.astro';
import Sidebar from '../../components/admin/Sidebar.astro';
import ListView from '../../components/admin/ListView.astro';
import Toolbar from '../../components/admin/Toolbar.astro';
import Modal from '../../components/admin/Modal.astro';
import '../../styles/admin.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>cms</title>
</head>
<body>

  <Login />

  <div class="app" id="app">
    <Sidebar />

    <main class="main" id="main">
      <ListView />

      <div id="editor-view" style="display:none; flex-direction:column; height:100%;">
        <div class="editor-bar">
          <div class="editor-bar-left">
            <button class="btn-back" id="ed-back" title="Back to list" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            </button>
            <span class="badge" id="ed-status"></span>
            <span class="editor-bar-slug" id="ed-slug"></span>
          </div>
          <div class="editor-bar-right">
            <button class="btn btn-ghost" id="ed-delete" type="button">Delete</button>
            <button class="btn btn-outline" id="ed-save" type="button">Save Draft</button>
            <button class="btn btn-primary" id="ed-publish" type="button">Publish</button>
          </div>
        </div>
        <div class="editor-scroll">
          <div class="ed-section">
            <div class="ed-section-title">General</div>
            <div class="ed-grid">
              <div class="ed-field"><label>Title</label><input type="text" id="ed-title" placeholder="Post title" /></div>
              <div class="ed-field"><label>Slug</label><input type="text" id="ed-slug-input" placeholder="post-slug" /></div>
              <div class="ed-field span"><label>Description</label><input type="text" id="ed-desc" placeholder="Brief description" /></div>
              <div class="ed-field"><label>Date</label><input type="date" id="ed-date" /></div>
              <div class="ed-field"><label>Category</label><input type="text" id="ed-category" placeholder="e.g. Embedded" /></div>
              <div class="ed-field span"><label>Tags</label><input type="text" id="ed-tags" placeholder="embedded, stm32 (comma separated)" /></div>
            </div>
          </div>
          <div class="ed-section" id="section-writing" style="display:none">
            <div class="ed-section-title">Series</div>
            <div class="ed-grid">
              <div class="ed-field"><label>Series</label><input type="text" id="ed-series" placeholder="Optional series name" /></div>
              <div class="ed-field"><label>Part</label><input type="number" id="ed-part" placeholder="1" min="1" /></div>
            </div>
          </div>
          <div class="ed-section" id="section-projects" style="display:none">
            <div class="ed-section-title">Project</div>
            <div class="ed-grid">
              <div class="ed-field"><label>Repo URL</label><input type="text" id="ed-repo" placeholder="https://github.com/..." /></div>
              <div class="ed-field"><label>Status</label><select id="ed-status-select"><option value="">None</option><option value="in-progress">In Progress</option><option value="completed">Completed</option></select></div>
            </div>
            <div class="ed-toggles" style="margin-top:0.65rem">
              <label class="ed-toggle"><input type="checkbox" id="ed-featured" /> Featured on homepage</label>
            </div>
          </div>
          <div class="ed-section">
            <div class="ed-section-title">Options</div>
            <div class="ed-toggles">
              <label class="ed-toggle"><input type="checkbox" id="ed-draft" checked /> Draft</label>
            </div>
          </div>
          <div class="ed-section ed-content">
            <div class="ed-section-title">Content</div>
            <Toolbar />
            <div class="ed-editor" id="ed-body" contenteditable="true" data-placeholder="Start writing your content... Use markdown syntax or the toolbar above."></div>
            <textarea id="ed-body-md" style="display:none"></textarea>
          </div>
        </div>
      </div>

    </main>
  </div>

  <Modal />

  <div class="toast-box" id="toasts"></div>

  <script>
    import { checkAuth, loadPosts, renderList, hydrateCard, showList, showCollectionFields, save, deletePost, setCurrent, setView, setQuery, current, view, toast } from '../../lib/cms/cms';
    import { setEditorContent, getEditorContent, handleToolbarAction, handleEditorKeydown, handleEditorInput } from '../../lib/cms/editor';
    import { handleEditorPaste, handleEditorDrop, uploadPendingImages, replacePendingUrls, getPendingImageCount } from '../../lib/cms/image-upload';

    const $ = (s: string) => document.querySelector(s) as HTMLElement;

    let currentView: 'writing' | 'projects' = 'writing';

    function openPost(slug: string) {
      $('#list-view').style.display = 'none';
      $('#editor-view').style.display = 'flex';
      document.querySelectorAll('.post-card').forEach(el => el.classList.remove('active'));
      $(`.post-card[data-slug="${CSS.escape(slug)}"]`)?.classList.add('active');

      $('#ed-status').className = 'badge saving'; $('#ed-status').textContent = 'LOADING';
      $('#ed-slug').textContent = slug;
      $('#ed-title').value = '';

      fetch(`/api/posts/${slug}`)
        .then(r => r.ok ? r.json() : Promise.reject())
        .then((d) => {
          setCurrent(d);
          const fm = d.frontmatter;
          const draft = fm.draft === true || fm.draft === 'true';
          $('#ed-status').className = `badge ${draft ? 'draft' : 'published'}`;
          $('#ed-status').textContent = draft ? 'DRAFT' : 'PUBLISHED';
          $('#ed-slug').textContent = d.slug;
          $('#ed-slug-input').value = d.slug;
          $('#ed-title').value = fm.title || '';
          $('#ed-desc').value = fm.description || '';
          $('#ed-date').value = fm.date || '';
          $('#ed-category').value = fm.category || '';
          $('#ed-tags').value = Array.isArray(fm.tags) ? fm.tags.join(', ') : (fm.tags || '');
          $('#ed-draft').checked = draft;
          showCollectionFields(d.collection);
          if (d.collection === 'projects') {
            $('#ed-featured').checked = fm.featured === true;
            $('#ed-repo').value = fm.repo || '';
            $('#ed-status-select').value = fm.status || '';
          } else {
            $('#ed-series').value = fm.series || '';
            $('#ed-part').value = fm.part || '';
          }
          setEditorContent(d.body || '');
        })
        .catch(() => toast('Failed to load post', 'error'));
    }

    function openModal() { $('#modal').classList.add('open'); $('#m-slug').value = ''; $('#m-slug').focus(); }
    function closeModal() { $('#modal').classList.remove('open'); }

    function createPost() {
      const slug = $('#m-slug').value.trim();
      if (!slug) { toast('Slug required', 'error'); return; }
      closeModal();
      setCurrent(null);
      $('#list-view').style.display = 'none';
      $('#editor-view').style.display = 'flex';
      $('#ed-status').className = 'badge draft'; $('#ed-status').textContent = 'DRAFT';
      $('#ed-slug').textContent = slug;
      $('#ed-slug-input').value = slug;
      $('#ed-title').value = ''; $('#ed-desc').value = '';
      $('#ed-date').value = new Date().toISOString().split('T')[0];
      $('#ed-category').value = ''; $('#ed-tags').value = '';
      $('#ed-draft').checked = true;
      showCollectionFields(currentView);
      if (currentView === 'projects') { $('#ed-featured').checked = false; $('#ed-repo').value = ''; $('#ed-status-select').value = ''; }
      else { $('#ed-series').value = ''; $('#ed-part').value = ''; }
      setEditorContent('');
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const authed = await checkAuth();
      if (authed) {
        await loadPosts();
        renderList(hydrateCard);
      }

      // Sidebar nav
      document.querySelectorAll('.sb-link[data-view]').forEach(link => {
        link.addEventListener('click', () => {
          document.querySelectorAll('.sb-link[data-view]').forEach(l => l.classList.remove('active'));
          link.classList.add('active');
          currentView = (link as HTMLElement).dataset.view as 'writing' | 'projects';
          setView(currentView);
          showList();
          renderList(hydrateCard);
        });
      });

      $('#search').addEventListener('input', (e) => {
        const q = (e.target as HTMLInputElement).value;
        setQuery(q);
        renderList(hydrateCard);
      });

      $('#new-btn').addEventListener('click', openModal);
      $('#m-cancel').addEventListener('click', closeModal);
      $('#m-create').addEventListener('click', createPost);
      $('#modal').addEventListener('click', (e) => { if (e.target === $('#modal')) closeModal(); });
      async function saveWithImages(publish: boolean) {
        const count = getPendingImageCount();
        if (count > 0) {
          toast(`Uploading ${count} image${count > 1 ? 's' : ''}...`);
          const collection = current?.collection || currentView;
          const replacements = await uploadPendingImages(collection);
          if (replacements === null) {
            toast('Image upload failed. Post not saved.', 'error');
            return;
          }
          replacePendingUrls(replacements);
        }
        save(publish, getEditorContent);
      }

      $('#ed-back').addEventListener('click', () => { showList(); renderList(hydrateCard); });
      $('#ed-save').addEventListener('click', () => saveWithImages(false));
      $('#ed-publish').addEventListener('click', () => saveWithImages(true));
      $('#ed-delete').addEventListener('click', deletePost);

      // Toolbar buttons
      document.querySelectorAll('.ed-toolbar-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const action = (btn as HTMLElement).dataset.action;
          if (action) handleToolbarAction(action);
        });
      });

      // Heading dropdown
      $('#ed-heading').addEventListener('change', (e) => {
        const value = (e.target as HTMLSelectElement).value;
        if (value) {
          handleToolbarAction(value);
          (e.target as HTMLSelectElement).value = '';
        }
      });

      // Editor events
      $('#ed-body').addEventListener('keydown', handleEditorKeydown);
      $('#ed-body').addEventListener('input', handleEditorInput);
      $('#ed-body').addEventListener('paste', (e) => handleEditorPaste(e as ClipboardEvent, currentView));
      $('#ed-body').addEventListener('drop', (e) => handleEditorDrop(e as DragEvent, currentView));
      $('#ed-body').addEventListener('dragover', (e) => e.preventDefault());

      // Global keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 's') {
          e.preventDefault();
          if ($('#editor-view').style.display !== 'none') saveWithImages(false);
        }
        if (e.key === 'Escape') {
          if ($('#modal').classList.contains('open')) closeModal();
          else if ($('#editor-view').style.display !== 'none') { showList(); renderList(hydrateCard); }
        }
      });

      // Custom event for opening posts
      document.addEventListener('openpost', ((e: CustomEvent) => {
        openPost(e.detail.slug);
      }) as EventListener);
    });
  </script>
</body>
</html>
