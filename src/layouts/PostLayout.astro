---
import BaseLayout from './BaseLayout.astro';

const { frontmatter, headings } = Astro.props;
const formatted = frontmatter.date
  ? new Date(frontmatter.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
  : null;
const metaParts = [formatted, frontmatter.category, ...(frontmatter.tags ?? [])].filter(Boolean);
---
<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  postMode={true}
  headings={headings}
  backHref="/writing"
>
  <article>
    <header>
      <p class="meta">
        {metaParts.map((part, i) => (
          <>
            {i > 0 && <span class="sep">&middot;</span>}
            <span>{part}</span>
          </>
        ))}
      </p>
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="description">{frontmatter.description}</p>}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .sep {
    color: var(--color-border);
    margin: 0 0.5em;
  }

  h1 {
    margin: 0 0 0.5rem;
  }

  .description {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-top: 0;
  }

  .prose {
    margin-top: 3rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
  }

  .prose :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 3.25rem;
    margin-bottom: 1rem;
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin: 1.1em 0;
    color: var(--color-text-secondary);
  }
</style>
