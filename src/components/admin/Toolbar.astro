---
// Toolbar component
---

<div class="ed-toolbar" id="ed-toolbar">
  <div class="ed-toolbar-group">
    <select class="ed-toolbar-select" id="ed-heading" title="Heading">
      <option value="">Heading</option>
      <option value="h1">H1</option>
      <option value="h2">H2</option>
      <option value="h3">H3</option>
      <option value="h4">H4</option>
      <option value="h5">H5</option>
      <option value="h6">H6</option>
    </select>
  </div>
  <div class="ed-toolbar-group">
    <button class="ed-toolbar-btn" data-action="bold" title="Bold (Ctrl+B)" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="italic" title="Italic (Ctrl+I)" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 4h-9M14 20H5M15 4L9 20"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="strikethrough" title="Strikethrough" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.3 4.9c-1.2-1.2-3.1-1.9-5.1-1.9-3.1 0-5.5 1.8-6.2 4.4M3 12h18M6.7 19.1c1.2 1.2 3.1 1.9 5.1 1.9 3.1 0 5.5-1.8 6.2-4.4"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="code" title="Inline Code" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/></svg>
    </button>
  </div>
  <div class="ed-toolbar-group">
    <button class="ed-toolbar-btn" data-action="ul" title="Bullet List" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="ol" title="Numbered List" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 6h11M10 12h11M10 18h11M3 5v2M3 10v1M3 16v4M3 8h2"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="task" title="Task List" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
    </button>
  </div>
  <div class="ed-toolbar-group">
    <button class="ed-toolbar-btn" data-action="quote" title="Blockquote" type="button">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="hr" title="Horizontal Rule" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
    </button>
  </div>
  <div class="ed-toolbar-group">
    <button class="ed-toolbar-btn" data-action="link" title="Link (Ctrl+K)" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="image" title="Image" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="table" title="Table" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>
    </button>
  </div>
  <div class="ed-toolbar-group">
    <button class="ed-toolbar-btn" data-action="codeblock" title="Code Block" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </button>
    <button class="ed-toolbar-btn" data-action="mdx" title="MDX Component" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
    </button>
  </div>
</div>
