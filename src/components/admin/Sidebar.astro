---
// Sidebar component
---

<aside class="sidebar">
  <div class="sb-brand"><h1>cms</h1></div>
  <nav class="sb-nav">
    <div class="sb-section">
      <div class="sb-label">Content</div>
      <button class="sb-link active" data-view="writing" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4z"/></svg>
        Writing <span class="count" id="count-writing">0</span>
      </button>
      <button class="sb-link" data-view="projects" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
        Projects <span class="count" id="count-projects">0</span>
      </button>
    </div>
    <div class="sb-divider"></div>
    <div class="sb-section">
      <div class="sb-label">Quick</div>
      <a class="sb-link" href="/" target="_blank">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
        View site
      </a>
    </div>
  </nav>
  <div class="sb-bottom">
    <div class="sb-user">
      <img id="u-av" src="" alt="" />
      <div class="sb-user-info">
        <span class="sb-user-name" id="u-name"></span>
        <span class="sb-user-role">Admin</span>
      </div>
    </div>
  </div>
  <div class="sb-footer">
    <a href="/api/auth/logout">Sign out</a>
  </div>
</aside>
