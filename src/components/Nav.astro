---
import { site } from '../data/site.js';

const { postMode = false, headings = [], backHref = "/writing" } = Astro.props;

// Edit this list to add/remove site-wide nav links.
const links = [
  { href: "/", label: "home" },
  { href: "/writing", label: "writing" },
  { href: "/projects", label: "projects" },
];
const current = Astro.url.pathname;
const toc = headings.filter(h => h.depth === 2);

// This nav is persisted across page transitions (transition:persist) so it
// never flickers or re-mounts while navigating between the site's list
// pages — but persistence means Astro will KEEP the old DOM node instead of
// swapping in the new page's version, which would be wrong the moment the
// content actually needs to change (site links vs. a post's own TOC, or
// moving from one post to a different post with different headings). Giving
// each distinct "shape" of nav its own transition:name means Astro only
// persists when navigating between pages that share the same name — i.e.
// freely between home/writing/projects, but not into/out of a post, and not
// between two different posts.
const transitionName = postMode
  ? `nav-post-${Astro.url.pathname.replace(/\//g, '-')}`
  : 'nav-site';
---
<nav class="floating-nav" transition:name={transitionName} transition:persist>
  {postMode ? (
    <div class="post-nav">
      <a href={backHref} class="return">&larr; return</a>
      {toc.length > 0 && (
        <div class="toc">
          <span class="toc-indicator" id="toc-indicator"></span>
          {toc.map(h => (
            <a href={`#${h.slug}`} data-slug={h.slug} class="toc-link">{h.text}</a>
          ))}
        </div>
      )}
    </div>
  ) : (
    <div class="site-nav">
      {links.map(link => (
        <a
          href={link.href}
          data-href={link.href}
          class:list={["nav-link", { active: current === link.href }]}
        >
          {link.label}
        </a>
      ))}
      <button type="button" id="palette-trigger" class="nav-link palette-btn">
        search <span class="kbd">&#8984;K</span>
      </button>
      <div class="social">
        <a href={site.social.github} class="nav-link" target="_blank" rel="noopener">github</a>
        <a href={site.social.email} class="nav-link">mail</a>
        <a href={site.social.linkedin} class="nav-link" target="_blank" rel="noopener">linkedin</a>
      </div>
    </div>
  )}
</nav>

<script>
  // Keeps the "active" link in sync with the current page. This has to be
  // done in JS (not just left to Astro's server-rendered class) because
  // the nav above is persisted across transitions — a persisted element's
  // DOM is reused as-is, so the class baked in at build time for the FIRST
  // page visited would otherwise stay stuck on every later navigation.
  function updateActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll('.nav-link[data-href]').forEach((link) => {
      const href = (link as HTMLElement).dataset.href;
      link.classList.toggle('active', href === path);
    });
  }

  document.addEventListener('astro:page-load', updateActiveNav);
</script>

{postMode && toc.length > 0 && (
  <script>
    // Highlights the currently visible section in the floating TOC as the
    // reader scrolls. Runs on load AND after each view-transition
    // navigation (astro:page-load) — without that second listener, moving
    // between posts via the soft-navigation router would leave the old
    // observer pointed at a DOM that no longer exists.
    function setupTOC() {
      const links = document.querySelectorAll('.toc-link');
      if (links.length === 0) return;

      const tocContainer = document.querySelector('.toc') as HTMLElement | null;
      const indicator = document.getElementById('toc-indicator');

      const sections = [...links]
        .map(link => document.getElementById((link as HTMLElement).dataset.slug || ''))
        .filter((el): el is HTMLElement => !!el);
      if (sections.length === 0) return;

      function moveIndicator(link: Element | null) {
        if (!indicator || !tocContainer || !link) return;
        const linkRect = link.getBoundingClientRect();
        const containerRect = tocContainer.getBoundingClientRect();
        indicator.style.transform = `translateY(${linkRect.top - containerRect.top}px)`;
        indicator.style.height = `${linkRect.height}px`;
        indicator.classList.add('visible');
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            const link = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('active'));
              link?.classList.add('active');
              moveIndicator(link);
            }
          });
        },
        { rootMargin: '-10% 0px -70% 0px' }
      );
      sections.forEach(section => observer.observe(section));
    }

    document.addEventListener('astro:page-load', setupTOC);
  </script>
)}

<style>
  .floating-nav {
    position: fixed;
    left: 2.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .site-nav,
  .post-nav {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    align-items: flex-start;
    text-align: left;
  }

  .nav-link,
  .return,
  .toc-link {
    color: var(--color-text-muted);
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active,
  .return:hover {
    color: var(--color-text);
  }

  .palette-btn {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .kbd {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .toc {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    padding-left: 0.75rem;
    border-top: 1px solid var(--color-border);
    max-width: 11rem;
  }

  .toc-indicator {
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 2px;
    background: var(--color-text);
    opacity: 0;
    transition: transform 0.25s ease, height 0.25s ease, opacity 0.2s ease;
  }

  .toc-indicator.visible {
    opacity: 1;
  }

  .social {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-top: 0.6rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--color-border);
  }

  .toc-link {
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--color-text);
  }

  .toc-link.active {
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .floating-nav {
      position: static;
      transform: none;
      display: flex;
      justify-content: flex-start;
      padding: 2rem 0 1.25rem;
      border-bottom: 1px solid var(--color-border);
    }

    .site-nav,
    .post-nav {
      flex-direction: row;
      gap: 1.25rem;
      align-items: center;
    }

    .social {
      flex-direction: row;
      gap: 1.25rem;
      margin-top: 0;
      padding-top: 0;
      padding-left: 1.1rem;
      border-top: none;
      border-left: 1px solid var(--color-border);
    }

    .toc {
      display: none; /* keep mobile simple — just "return" */
    }
  }
</style>
