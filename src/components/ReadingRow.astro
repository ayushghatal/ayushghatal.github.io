---
const { title, author, status } = Astro.props;
---
<div class="row">
  <div class="row-top">
    <h3>{title}</h3>
    <span class="status">{status}</span>
  </div>
  {author && <p>{author}</p>}
</div>

<style>
  .row-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  h3 {
    margin: 0;
    color: var(--color-text-secondary);
    transition: color 0.15s ease;
  }

  .row:hover h3 {
    color: var(--color-text);
  }

  .status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  p {
    margin: 0.3rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
