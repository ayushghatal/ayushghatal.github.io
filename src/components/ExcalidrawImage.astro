---
interface Props {
  src: string;
  alt: string;
  width?: string;
  caption?: string;
}

const { src, alt, width = "100%", caption } = Astro.props;
---

<figure class="excalidraw-figure">
  <img src={src} alt={alt} width={width} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .excalidraw-figure {
    margin: 1.5rem 0;
    text-align: center;
  }
  .excalidraw-figure img {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid #2a2a2a;
  }
  .excalidraw-figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: #888;
  }
</style>
