# GitHub OAuth App (create at https://github.com/settings/applications/new)
# Homepage URL: http://localhost:4321
# Authorization callback URL: http://localhost:4321/api/auth/callback
GITHUB_OAUTH_ID=your_github_oauth_app_client_id
GITHUB_OAUTH_SECRET=your_github_oauth_app_client_secret

# GitHub repo for CMS commits
# Format: owner/repo
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
